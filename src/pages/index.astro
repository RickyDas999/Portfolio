---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import About from '../components/About.astro';
---

<Layout title="YOUR_NAME — Portfolio">
	<main class="mx-auto max-w-5xl px-6">
		<Hero />

		<Projects />

		<About />

		<section id="contact" class="min-h-[40vh] scroll-mt-20 border-t border-slate-800 py-20">
			<h2 class="text-2xl font-semibold tracking-tight">Contact</h2>
			<p class="mt-4 text-slate-400">Content coming in a future checkpoint.</p>
		</section>
	</main>
</Layout>
