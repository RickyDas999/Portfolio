---
import Layout from '../layouts/Layout.astro';
---

<Layout title="YOUR_NAME — Portfolio">
	<main class="mx-auto max-w-5xl px-6">
		<section id="home" class="flex min-h-[70vh] flex-col justify-center">
			<h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Hero section placeholder</h1>
			<p class="mt-4 max-w-xl text-slate-400">Content coming in the next checkpoint.</p>
		</section>

		<section id="projects" class="min-h-[40vh] scroll-mt-20 border-t border-slate-800 py-20">
			<h2 class="text-2xl font-semibold tracking-tight">Projects</h2>
			<p class="mt-4 text-slate-400">Content coming in a future checkpoint.</p>
		</section>

		<section id="about" class="min-h-[40vh] scroll-mt-20 border-t border-slate-800 py-20">
			<h2 class="text-2xl font-semibold tracking-tight">About</h2>
			<p class="mt-4 text-slate-400">Content coming in a future checkpoint.</p>
		</section>

		<section id="contact" class="min-h-[40vh] scroll-mt-20 border-t border-slate-800 py-20">
			<h2 class="text-2xl font-semibold tracking-tight">Contact</h2>
			<p class="mt-4 text-slate-400">Content coming in a future checkpoint.</p>
		</section>
	</main>
</Layout>
