---
import type { Project } from '../data/projects';

interface Props extends Project {}

const { title, description, tags, repoUrl, liveUrl } = Astro.props;
---

<article class="flex flex-col rounded-lg border border-slate-800 p-6 transition-colors hover:border-slate-600">
	<h3 class="text-lg font-semibold text-slate-100">{title}</h3>
	<p class="mt-2 flex-1 text-sm text-slate-400">{description}</p>
	<ul class="mt-4 flex flex-wrap gap-2">
		{tags.map((tag) => (
			<li class="rounded-full bg-slate-800 px-2.5 py-1 text-xs text-slate-300">{tag}</li>
		))}
	</ul>
	<div class="mt-5 flex gap-4 text-sm font-medium">
		{repoUrl && (
			<a href={repoUrl} class="text-sky-400 transition-colors hover:text-sky-300">Code</a>
		)}
		{liveUrl && (
			<a href={liveUrl} class="text-sky-400 transition-colors hover:text-sky-300">Live</a>
		)}
	</div>
</article>
