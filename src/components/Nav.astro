---
const links = [
	{ href: '#projects', label: 'Projects' },
	{ href: '#about', label: 'About' },
	{ href: '#contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/80 backdrop-blur">
	<nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
		<a href="#" class="text-lg font-semibold tracking-tight text-slate-100">
			Subham (Ricky) Das
		</a>
		<ul class="flex gap-6 text-sm text-slate-300">
			{links.map((link) => (
				<li>
					<a href={link.href} class="transition-colors hover:text-slate-100">
						{link.label}
					</a>
				</li>
			))}
		</ul>
	</nav>
</header>
