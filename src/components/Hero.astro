---
const role = 'Software Engineer';
const tagline =
	'I am a Computer Sciences graduate from the University of Wisconsin-Madison with minors in Business and Entrepreneurship, passionate about building software that solves real-world problems. My experience spans full-stack development, cloud-based backend systems, data visualization, and AI-driven tools, with a focus on creating scalable and efficient solutions. I enjoy collaborating with teams, breaking down complex problems, and using technology to deliver meaningful impact.';
---

<section id="home" class="flex min-h-[80vh] flex-col justify-center">
	<p class="text-sm font-medium uppercase tracking-widest text-slate-400">{role}</p>
	<h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-6xl">
		Hi, I'm <span class="text-sky-400">Subham (Ricky) Das</span>.
	</h1>
	<p class="mt-6 max-w-xl text-lg text-slate-400">{tagline}</p>
	<div class="mt-8 flex flex-wrap gap-4">
		<a
			href="#projects"
			class="rounded-md bg-sky-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition-colors hover:bg-sky-400"
		>
			View Projects
		</a>
		<a
			href="#contact"
			class="rounded-md border border-slate-700 px-5 py-2.5 text-sm font-semibold text-slate-100 transition-colors hover:border-slate-500"
		>
			Get in Touch
		</a>
	</div>
</section>
