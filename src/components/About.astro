---
const bio = [
	"I am a Computer Sciences graduate from the University of Wisconsin–Madison (minors in Business and Entrepreneurship) who graduated May 2026. Previously, I interned as a Software Development Engineer at Amazon Web Services, building a workflow visibility system used across Amazon organizations, and as a Software Asset Management Specialist at Johnson & Johnson.",
	"I care about turning ambiguous problems into scalable, well-tested systems — spanning full-stack development, cloud backends, and data-driven tooling. Outside of engineering, I founded Food For All, a non-profit coordinating food donations in Somerset County, NJ.",
];

const skills = [
	'Java',
	'Python',
	'JavaScript',
	'C',
	'Kotlin',
	'SQL',
	'React.js',
	'React Native',
	'AWS (Lambda, DynamoDB, SageMaker, CloudWatch)',
	'Flask',
	'Power BI',
	'Tableau',
];

const resumeUrl = `${import.meta.env.BASE_URL}/resume.pdf`.replace(/\/{2,}/g, '/');
---

<section id="about" class="scroll-mt-20 border-t border-slate-800 py-20">
	<h2 class="text-2xl font-semibold tracking-tight">About</h2>
	<div class="mt-8 grid gap-10 sm:grid-cols-3">
		<div class="sm:col-span-2">
			{bio.map((paragraph) => (
				<p class="mt-4 text-slate-400 first:mt-0">{paragraph}</p>
			))}
			<a
				href={resumeUrl}
				target="_blank"
				rel="noopener"
				class="mt-6 inline-block rounded-md border border-slate-700 px-5 py-2.5 text-sm font-semibold text-slate-100 transition-colors hover:border-slate-500"
			>
				Download Resume
			</a>
		</div>
		<div>
			<h3 class="text-sm font-medium uppercase tracking-widest text-slate-400">Skills</h3>
			<ul class="mt-4 flex flex-wrap gap-2">
				{skills.map((skill) => (
					<li class="rounded-full bg-slate-800 px-2.5 py-1 text-xs text-slate-300">{skill}</li>
				))}
			</ul>
		</div>
	</div>
</section>
