---
const year = new Date().getFullYear();
const socials = [
	{ href: 'https://github.com/RickyDas999', label: 'GitHub' },
	{ href: '#', label: 'LinkedIn' },
	{ href: 'mailto:YOUR_EMAIL@example.com', label: 'Email' },
];
---

<footer class="border-t border-slate-800">
	<div class="mx-auto flex max-w-5xl flex-col items-center gap-4 px-6 py-10 text-sm text-slate-400 sm:flex-row sm:justify-between">
		<p>&copy; {year} YOUR_NAME. All rights reserved.</p>
		<ul class="flex gap-5">
			{socials.map((social) => (
				<li>
					<a href={social.href} class="transition-colors hover:text-slate-100">
						{social.label}
					</a>
				</li>
			))}
		</ul>
	</div>
</footer>
